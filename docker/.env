# ============================================================
# ShapeRise Arena – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
SERVER_PORT=7777          # UDP port exposed to clients

# ── Game Settings ───────────────────────────────────────────
MAX_PLAYERS=4             # 2 or 4
BOT_FILL_TIMEOUT=60       # Seconds to wait before bot fills empty slots
HEIGHT_TARGET=1000        # Win condition: kule yüksekliği (birim)
GAME_MODE=FFA             # FFA (Free-for-All) | TEAM2V2
